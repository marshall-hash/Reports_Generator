{
  "name": "reports_generator",
  "version": "1.0.0",
  "description": "An app that produces school reports from Excel files",
  "author": "Tafadzwa Marshall Mugoni",
  "license": "ISC",
  "type": "commonjs",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build-react": "cd frontend && npm run build",
    "dist": "npm run build-react && electron-builder"
  },

  "build": {
    "appId": "com.reports.generator",
    "productName": "Reports Generator",

     "files": [
    "frontend/dist/**/*",
    "backend/**/*",
    "main.js"
    ],

    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],

    "asar": true,
    "asarUnpack": [
      "backend/**"
    ],

    "win": {
      "target": "nsis",
      "icon": "build/high.ico"
    }
  },

  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  }
}